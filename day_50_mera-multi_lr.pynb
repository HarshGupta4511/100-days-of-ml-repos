ent fitted\"><pre>LinearRegression()</pre></div> </div></div></div></div>"},"metadata":{}}],"execution_count":15},{"cell_type":"code","source":"pred_y = lr.predict(x_test)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-15T15:44:21.238553Z","iopub.execute_input":"2026-07-15T15:44:21.238814Z","iopub.status.idle":"2026-07-15T15:44:21.242286Z","shell.execute_reply.started":"2026-07-15T15:44:21.238766Z","shell.execute_reply":"2026-07-15T15:44:21.241695Z"}},"outputs":[],"execution_count":16},{"cell_type":"code","source":"from sklearn.metrics import r2_score","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-15T15:44:52.401061Z","iopub.execute_input":"2026-07-15T15:44:52.401295Z","iopub.status.idle":"2026-07-15T15:44:52.404823Z","shell.execute_reply.started":"2026-07-15T15:44:52.401275Z","shell.execute_reply":"2026-07-15T15:44:52.404192Z"}},"outputs":[],"execution_count":17},{"cell_type":"code","source":"r2_score(y_test,pred_y)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-15T15:45:19.351054Z","iopub.execute_input":"2026-07-15T15:45:19.351301Z","iopub.status.idle":"2026-07-15T15:45:19.356619Z","shell.execute_reply.started":"2026-07-15T15:45:19.35128Z","shell.execute_reply":"2026-07-15T15:45:19.356028Z"}},"outputs":[{"execution_count":19,"output_type":"execute_result","data":{"text/plain":"0.4399338661568968"},"metadata":{}}],"execution_count":19},{"cell_type":"markdown","source":"My own class for LinearRegression","metadata":{"execution":{"iopub.status.busy":"2026-07-15T15:45:51.526164Z","iopub.execute_input":"2026-07-15T15:45:51.526389Z","iopub.status.idle":"2026-07-15T15:45:51.531094Z","shell.execute_reply.started":"2026-07-15T15:45:51.52637Z","shell.execute_reply":"2026-07-15T15:45:51.530291Z"}}},{"cell_type":"code","source":"class Meralr:\n\n    def __init__(self):\n        self.coef_ = None\n        self.intercept_ = None\n\n    def model(self,x_train,y_train):\n        x_train = np.insert(x_train,0,1,axis=1)\n        betas = np.linalg.inv(np.dot(x_train.T,x_train)).dot(x_train.T).dot(y_train)\n        self.intercept_ = betas[0]\n        self.coef_ = betas[1:]\n\n    \n    def predict(self,x_test):\n        y_pred = np.dot(x_test,self.coef_) + self.intercept_\n        return y_pred","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-15T16:09:31.770733Z","iopub.execute_input":"2026-07-15T16:09:31.771027Z","iopub.status.idle":"2026-07-15T16:09:31.775712Z","shell.execute_reply.started":"2026-07-15T16:09:31.771004Z","shell.execute_reply":"2026-07-15T16:09:31.774974Z"}},"outputs":[],"execution_count":38},{"cell_type":"code","source":"lr = Meralr()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-15T16:09:31.946515Z","iopub.execute_input":"2026-07-15T16:09:31.946756Z","iopub.status.idle":"2026-07-15T16:09:31.950262Z","shell.execute_reply.started":"2026-07-15T16:09:31.946736Z","shell.execute_reply":"2026-07-15T16:09:31.949501Z"}},"outputs":[],"execution_count":39},{"cell_type":"code","source":"lr.model(x_train,y_train)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-15T16:09:32.126296Z","iopub.execute_input":"2026-07-15T16:09:32.126538Z","iopub.status.idle":"2026-07-15T16:09:32.130596Z","shell.execute_reply.started":"2026-07-15T16:09:32.126518Z","shell.execute_reply":"2026-07-15T16:09:32.130087Z"}},"outputs":[],"execution_count":40},{"cell_type":"code","source":"lr.coef_","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-15T16:09:32.32117Z","iopub.execute_input":"2026-07-15T16:09:32.321404Z","iopub.status.idle":"2026-07-15T16:09:32.32648Z","shell.execute_reply.started":"2026-07-15T16:09:32.321385Z","shell.execute_reply":"2026-07-15T16:09:32.325868Z"}},"outputs":[{"execution_count":41,"output_type":"execute_result","data":{"text/plain":"array([  -9.15865318, -205.45432163,  516.69374454,  340.61999905,\n       -895.5520019 ,  561.22067904,  153.89310954,  126.73139688,\n        861.12700152,  